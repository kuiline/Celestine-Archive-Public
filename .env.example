# Optional local proxy for image-generation upstreams.
# Keep real local overrides in .env.local, which is ignored by Git.
# IMAGE_PROXY_URL=http://127.0.0.1:7897

# Optional IdleCloud routing controls.
# IDLECLOUD_USE_PROXY=1
# IDLECLOUD_ROUTE_FALLBACK=0
# IDLECLOUD_STABILITY_GUARD=0

# Optional local-only UI title.
# VITE_APP_TITLE=Celestial Archive
# VITE_PORTRAIT_MIRROR_VIDEO_NAME=
